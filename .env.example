# PostgreSQL bağlantı URL'i
DATABASE_URL=postgresql+asyncpg://gymgate:gymgate@localhost:5432/gymgate

# Redis bağlantı URL'i
REDIS_URL=redis://localhost:6379

# Fernet şifreleme anahtarı (QR payload şifreleme için)
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# JWT imzalama anahtarı
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
